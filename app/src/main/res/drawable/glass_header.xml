<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Frosted glass effect with semi-transparent gradient -->
    <gradient 
        android:type="linear"
        android:angle="270"
        android:startColor="#E61a1a2e"
        android:endColor="#B316213e" />
    
    <!-- Subtle bottom border -->
    <stroke 
        android:width="1dp"
        android:color="#33FFFFFF" />
    
    <corners 
        android:bottomLeftRadius="16dp"
        android:bottomRightRadius="16dp" />
    
</shape>

<!-- 
    Glass Header - Frosted effect for app bar
    Semi-transparent with subtle border for depth
-->