<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Spacer to push content to center -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_politai_logo"
            android:contentDescription="PoLiTAI Logo"
            android:layout_marginBottom="24dp" />

        <!-- App Name -->
        <TextView
            android:id="@+id/splashAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PoLiTAI"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Co-Pilot for Indian Governance"
            android:textSize="16sp"
            android:textColor="@color/white_alpha_70"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.05" />

        <!-- Version Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MASTER GRADE EDITION"
            android:textSize="10sp"
            android:textColor="@color/purple_500"
            android:background="@drawable/badge_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Loading Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Loading Text -->
            <TextView
                android:id="@+id/splashLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initializing AI Engine..."
                android:textSize="14sp"
                android:textColor="@color/white_alpha_70"
                android:layout_marginBottom="16dp" />

            <!-- Progress Bar -->
            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="4dp"
                android:background="@color/white_alpha_20"
                android:layout_marginBottom="48dp">

                <View
                    android:id="@+id/splashProgress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_gradient" />
            </FrameLayout>

        </LinearLayout>

        <!-- Developer Watermark (at bottom) -->
        <TextView
            android:id="@+id/splashDeveloper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Developed by Rishit Rohan"
            android:textSize="12sp"
            android:textColor="@color/white_alpha_50"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

    <!-- Decorative Elements -->
    <!-- Top Right Glow -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:background="@drawable/glow_circle"
        android:alpha="0.3"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp" />

    <!-- Bottom Left Glow -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/glow_circle"
        android:alpha="0.2"
        android:layout_marginBottom="-100dp"
        android:layout_marginStart="-100dp" />

</FrameLayout>