<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    
    <!-- Purple gradient for send button -->
    <gradient 
        android:type="linear"
        android:angle="135"
        android:startColor="#7C3AED"
        android:endColor="#4F46E5" />
    
    <!-- Subtle glow effect -->
    <stroke 
        android:width="2dp"
        android:color="#60A5FA" />
    
</shape>

<!-- 
    Circle Send Button - Purple gradient with glow
    Matches user message bubble styling
-->