<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="16dp"
    android:gravity="bottom">

    <!-- App Logo/Icon -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_politai_logo"
        android:contentDescription="PoLiTAI Logo"
        android:layout_marginBottom="8dp" />

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PoLiTAI"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Co-Pilot for Indian Governance"
        android:textColor="@color/white_alpha_70"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v2.0 - Master Grade"
        android:textColor="@color/white_alpha_50"
        android:textSize="10sp"
        android:layout_marginTop="8dp" />

</LinearLayout>