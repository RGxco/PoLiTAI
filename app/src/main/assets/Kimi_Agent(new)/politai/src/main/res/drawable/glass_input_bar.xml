<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Frosted glass effect -->
    <solid android:color="#CC1a1a2e" />
    
    <!-- Top border for separation -->
